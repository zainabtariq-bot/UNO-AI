import random
import copy

class Card:
    def __init__(self, color, number):
        self.color = color
        self.number = number

    def skip(self):
        return self.number == "Skip"

    def __repr__(self):
        return f"{self.color} {self.number}"

    def __eq__(self, other):
        return isinstance(other, Card) and \
               self.color == other.color and \
               self.number == other.number

    def __hash__(self):
        return hash((self.color, self.number))


def generate_deck():
    colors = ["Red", "Blue", "Green", "Yellow"]
    numbers = list(range(10)) + ["Skip"]

    deck = [Card(color, num) for color in colors for num in numbers]
    random.shuffle(deck)
    return deck

