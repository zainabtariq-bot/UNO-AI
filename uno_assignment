    print("Top card:", top)

    print("\nYour hand:")
    for i, card in enumerate(hand):
        print(f"{i}: {card}")

    if valid_moves:
        print("\nValid moves:")
        valid_indices = [i for i, c in enumerate(hand) if c in valid_moves]
        for i in valid_indices:
            print(f"{i}: {hand[i]}")

        choice = input("Enter card index to play or 'd' to draw: ")

        if choice.lower() == 'd':
            return None
        else:
            choice = int(choice)
            if choice in valid_indices:
                return hand[choice]
            else:
